# ============================================
# MTG Camera Translator & Card Finder
# Variáveis de Ambiente (Template)
# ============================================
# COPIE este arquivo para .env e preencha:
#   cp .env.example .env

# Django
SECRET_KEY=coloque-uma-chave-secreta-aqui
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# OpenRouter API (IA de Visão)
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxxx
OPENROUTER_MODEL=google/gemini-2.0-flash-001

# Rate Limiting
IDENTIFY_RATE_LIMIT=10/min
IDENTIFY_BURST_LIMIT=3/sec

# Upload
MAX_UPLOAD_SIZE_MB=5
